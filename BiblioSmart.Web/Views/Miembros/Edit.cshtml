@model BiblioSmart.Core.Entities.Miembro
@{ ViewData["Title"] = "Editar Miembro"; }

<h2 class="mb-4">Editar Miembro</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="NombreCompleto" class="form-label">Nombre Completo</label>
                <input asp-for="NombreCompleto" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Cedula" class="form-label">Cédula</label>
                <input asp-for="Cedula" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Correo" class="form-label">Correo Electrónico</label>
                <input asp-for="Correo" class="form-control" type="email" />
            </div>
            <div class="mb-3">
                <label asp-for="Telefono" class="form-label">Teléfono</label>
                <input asp-for="Telefono" class="form-control" />
            </div>
            <button type="submit" class="btn btn-warning">Actualizar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
