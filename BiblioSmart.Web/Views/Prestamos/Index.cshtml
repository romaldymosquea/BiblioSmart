@model IEnumerable<BiblioSmart.Core.Entities.Prestamo>
@{ ViewData["Title"] = "Préstamos"; }

<h2 class="mb-4">Gestión de Préstamos</h2>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">+ Nuevo Préstamo</a>
    <a asp-action="Reporte" class="btn btn-info ms-2">Ver Reporte</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Libro</th><th>Miembro</th><th>Fecha Préstamo</th><th>Fecha Devolución</th><th>Estado</th><th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Libro?.Titulo</td>
                <td>@p.Miembro?.NombreCompleto</td>
                <td>@p.FechaPrestamo.ToShortDateString()</td>
                <td>@p.FechaDevolucionEsperada.ToShortDateString()</td>
                <td>
                    <span class="badge @(p.Estado == "Activo" ? "bg-warning text-dark" : "bg-success")">
                        @p.Estado
                    </span>
                </td>
                <td>
                    @if (p.Estado == "Activo")
                    {
                        <a asp-action="Devolver" asp-route-id="@p.Id" class="btn btn-sm btn-success">Devolver</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
