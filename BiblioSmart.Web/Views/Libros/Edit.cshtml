@model BiblioSmart.Core.Entities.Libro
@{ ViewData["Title"] = "Editar Libro"; }

<h2 class="mb-4">Editar Libro</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Titulo" class="form-label">Título</label>
                <input asp-for="Titulo" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Autor" class="form-label">Autor</label>
                <input asp-for="Autor" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="ISBN" class="form-label">ISBN</label>
                <input asp-for="ISBN" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Categoria" class="form-label">Categoría</label>
                <input asp-for="Categoria" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="CantidadTotal" class="form-label">Cantidad Total</label>
                <input asp-for="CantidadTotal" class="form-control" type="number" min="1" />
            </div>
            <div class="mb-3">
                <label asp-for="CantidadDisponible" class="form-label">Cantidad Disponible</label>
                <input asp-for="CantidadDisponible" class="form-control" type="number" min="0" />
            </div>
            <button type="submit" class="btn btn-warning">Actualizar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
